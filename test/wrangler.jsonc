{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "lfs-server",
  "main": "./main.ts",
  "compatibility_date": "2026-05-08",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "public",
    "run_worker_first": true,
  },
  "r2_buckets": [
    {
      "binding": "LFS_BUCKET",
      "bucket_name": "lfs-objects",
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "LOCKS",
        "class_name": "Locks",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RepoLocks"],
    },
    {
      "tag": "v2",
      "renamed_classes": [{ "from": "RepoLocks", "to": "Locks" }],
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "OBJECT_EVENTS",
        "queue": "lfs-object-events",
      },
    ],
  },
  "vars": {
    "S3_ENDPOINT": "https://account-id.r2.cloudflarestorage.com",
    "S3_ACCESS_KEY_ID": "test-access-key-id",
    "S3_SECRET_ACCESS_KEY": "test-secret-access-key",
    "S3_BUCKET_NAME": "lfs-objects",
    "S3_PRESIGN_TTL": "3600",
    "GITHUB_APP_HOME": "https://test.example.com",
    "GITHUB_ORG": "Test-Org",
    "GITHUB_CLIENT_ID": "test-client-id",
    "GITHUB_CLIENT_SECRET": "test-client-secret",
    "LOGIN_SECRET": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
  },
}
