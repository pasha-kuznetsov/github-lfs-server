{
  "name": "github-lfs-server",
  "type": "module",
  "scripts": {
    "types": "wrangler types --env-interface CloudflareBindings",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project 'integration*'",
    "test:watch": "vitest watch",
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy --minify --outdir dist $(scripts/sentry-wrangler-args.sh)",
    "sentry:sourcemaps": "scripts/sentry-upload-sourcemaps.sh",
    "postdeploy": "bun run sentry:sourcemaps"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": "^26.1.0"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@octokit/rest": "^22.0.1",
    "@sentry/cloudflare": "^10.53.1",
    "@sentry/hono": "^10.53.1",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@sentry/cli": "^2",
    "@types/node": "^25.6.2",
    "miniflare": "^4.20260507.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  }
}
