{
  "name": "@git-lfs-hub/server",
  "type": "module",
  "scripts": {
    "types": "wrangler types --env-interface CloudflareBindings",
    "test": "scripts/init-test.sh && vitest run",
    "test:unit": "bun run test --project unit",
    "test:integration": "bun run test --project 'integration*'",
    "test:scripts": "bun run test --project 'scripts'",
    "test:watch": "scripts/init-test.sh && vitest watch",
    "test-coverage": "bun run test --coverage",
    "dev": "dev/start.ts",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy --minify --outdir dist $(scripts/sentry-wrangler-args.sh)",
    "sentry:sourcemaps": "scripts/sentry-upload-sourcemaps.sh",
    "postdeploy": "bun run sentry:sourcemaps"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": "^26.1.0"
  },
  "dependencies": {
    "@git-lfs-hub/auth": "file:../auth",
    "@hono/standard-validator": "^0.2.2",
    "@octokit/rest": "^22.0.1",
    "@sentry/cloudflare": "^10.53.1",
    "@sentry/hono": "^10.53.1",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.9",
    "hono": "^4.12.22",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@sentry/cli": "^3.4.3",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-istanbul": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "miniflare": "^4.20260521.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.94.0"
  }
}
